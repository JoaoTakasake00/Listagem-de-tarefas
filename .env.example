# ======================================
# Banco de Dados
# ======================================
# Host do banco (nome do serviço Docker ou hostname)
DB_HOST=db
# Porta TCP do banco
DB_PORT=3306
# Nome do banco da aplicação
DB_NAME=tasks_db
# Usuário com permissão de leitura/escrita
DB_USER=user
# Senha do usuário do banco
DB_PASSWORD=user

# ======================================
# JWT
# ======================================
# Chave secreta forte para assinar tokens JWT (mínimo 32 caracteres)
JWT_SECRET=troque_por_uma_chave_jwt_forte_e_unica
# Tempo de expiração do access token em segundos (ex.: 3600 = 1h)
JWT_EXPIRES_IN=3600
# Algoritmo de assinatura JWT suportado atualmente (HS256)
JWT_ALGORITHM=HS256
# Issuer do token JWT (identificador do serviço emissor)
JWT_ISSUER=taskflow-api

# ======================================
# Autenticação
# ======================================
# Usuário administrativo para login no sistema
AUTH_USERNAME=admin
# Hash bcrypt da senha do usuário administrativo
# Gere com: php -r "echo password_hash('SUA_SENHA', PASSWORD_BCRYPT), PHP_EOL;"
AUTH_PASSWORD_HASH=$2y$10$substitua_por_hash_bcrypt_valido

# Variáveis reservadas para evolução (refresh token / auth avançada)
# Segredo adicional para autenticação de longo prazo
AUTH_SECRET=troque_por_auth_secret_forte
# Expiração de sessão/autenticação auxiliar em segundos
TOKEN_EXPIRY=3600
# Segredo específico para refresh token
REFRESH_TOKEN_SECRET=troque_por_refresh_secret_forte
